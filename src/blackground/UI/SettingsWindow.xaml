<Window x:Class="blackground.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:blackground.UI"
        Title="blackground — Settings"
        Width="460" Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hotkey -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Hotkey" FontWeight="Bold" Margin="0,0,0,4"/>
            <ui:HotkeyCaptureBox x:Name="HotkeyBox" Padding="6,4"/>
            <TextBlock x:Name="HotkeyError" Foreground="#C62828" Margin="0,4,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Monitor scope -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Monitor scope" FontWeight="Bold" Margin="0,0,0,4"/>
            <RadioButton x:Name="ScopeActive" Content="Active window's monitor" GroupName="Scope" Margin="0,2"/>
            <RadioButton x:Name="ScopeAll" Content="All monitors" GroupName="Scope" Margin="0,2"/>
        </StackPanel>

        <!-- Opacity -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="Opacity" FontWeight="Bold"/>
                <TextBlock x:Name="OpacityLabel" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
            <Slider x:Name="OpacitySlider" Minimum="0.5" Maximum="1.0" SmallChange="0.05" LargeChange="0.05"
                    TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Start with Windows -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <CheckBox x:Name="StartWithWindowsCheck" Content="Start with Windows"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="StatusLabel" Margin="0,0,0,8" Foreground="#1565C0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ResetButton" Content="Reset to Defaults" Width="140" Margin="0,0,8,0" Click="ResetButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" IsCancel="True"/>
            <Button x:Name="SaveButton" Content="Save" Width="90" Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
